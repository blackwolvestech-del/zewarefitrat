# ——— ZEWARE FITRAT environment ———

# Admin panel password (REQUIRED in production — /admin/login)
ADMIN_PASSWORD=change-me-to-something-strong

# Optional: separate secret for signing admin sessions (defaults to a hash of the password)
# ADMIN_SECRET=

# Where products.json, orders.json and uploaded media live.
# On Coolify: attach a volume and point this at it, e.g. /app/data
# DATA_DIR=/app/data

# ——— Order notifications (all optional) ———

# WhatsApp to the owner via CallMeBot (free). Setup:
#  1) Save +34 644 74 82 80 (CallMeBot) to your contacts.
#  2) WhatsApp it: "I allow callmebot to send me messages"
#  3) It replies with your apikey. Put your number + key below.
# CALLMEBOT_PHONE=923000000000
# CALLMEBOT_APIKEY=123456

# OR POST each order to any automation (n8n, Zapier, Make, WhatsApp Cloud API proxy)
# ORDER_WEBHOOK_URL=https://your-automation-endpoint
