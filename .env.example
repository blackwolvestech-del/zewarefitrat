# Admin panel password (REQUIRED in production — /admin/login)
ADMIN_PASSWORD=change-me-to-something-strong

# Optional: separate secret for signing admin sessions (defaults to a hash of the password)
# ADMIN_SECRET=

# Where products.json, orders.json and uploaded media live.
# On Coolify: attach a volume and point this at it, e.g. /app/data
# DATA_DIR=/app/data
